export const runtime = 'nodejs';
import { NextRequest, NextResponse } from 'next/server'; import { cfbdResultsForTraining } from '@/lib/fetchers/cfbd';  export async function GET(req:NextRequest){try{const {searchParams}=new URL(req.url); const startYear=Number(searchParams.get('startYear')); const endYear=Number(searchParams.get('endYear')); const division=(searchParams.get('division')||'fbs') as 'fbs'|'fcs'|'ii'|'iii'; if(!Number.isFinite(startYear)||!Number.isFinite(endYear)||startYear>endYear){return NextResponse.json({error:'Valid startYear <= endYear required'},{status:400});} const rows=await cfbdResultsForTraining({startYear,endYear,division}); return NextResponse.json({startYear,endYear,division,games:rows}); }catch(e:any){return NextResponse.json({error:e?.message||'Unexpected error'},{status:500});}}